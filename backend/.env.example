# ── App ───────────────────────────────────────────────────────────────────────
# Environment: dev or prod
# Controls storage backend — MinIO in dev, real AWS S3 in prod
ENV=dev

# API route prefix
API_PREFIX=/api/v1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mock_interview_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# S3 bucket name for resume storage
S3_RESUME_BUCKET=your-bucket-name

# AWS region where the bucket is located
AWS_REGION=us-east-1

# Leave blank in production if using an EC2 IAM Role — boto3 picks up credentials automatically
# Only set these for local development if not using MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── MinIO (local dev only) ────────────────────────────────────────────────────
# Used when ENV=dev as a local S3-compatible store
# These match the default MinIO dev credentials
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
